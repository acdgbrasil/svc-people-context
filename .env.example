PORT=3000
SERVER_HOST=0.0.0.0

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=people

# Auth — Zitadel JWKS (JWT RS256 verification)
JWKS_URL=https://auth.acdgbrasil.com.br/oauth/v2/keys
ZITADEL_ISSUER=https://auth.acdgbrasil.com.br
ZITADEL_PROJECT_ID=363109883022671995

# Optional — Token introspection fallback for service accounts (HML only)
# ZITADEL_INTROSPECT_URL=https://auth.acdgbrasil.com.br/oauth/v2/introspect
# ZITADEL_INTROSPECT_CLIENT_ID=
# ZITADEL_INTROSPECT_CLIENT_SECRET=
# ALLOWED_SERVICE_ACCOUNTS=sub1,sub2

# Optional — Zitadel Management API (user provisioning disabled if not set)
# ZITADEL_MANAGEMENT_URL=https://auth.acdgbrasil.com.br
# ZITADEL_SERVICE_ACCOUNT_TOKEN=<PAT from Zitadel service account>

# Optional — NATS event publishing (disabled if not set)
NATS_URL=nats://localhost:4222
