{
  "name": "people-context",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "coverage": "bun test --coverage 2>&1 | tee /dev/stderr | node scripts/check-coverage.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "elysia": "1.4.28",
    "jose": "6.2.2",
    "nats": "2.29.3",
    "postgres": "3.4.8"
  }
}
